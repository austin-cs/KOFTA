% change the style of the caption numbering.
\def\FigName{figure}%
\def\fnum@figure{Fig.\nobreakspace\thefigure}
\long\def\@makecaption#1#2{%
  \def\currentcaption{\tablecaptionsize{\bfseries#1. #2}}
  \ifx\@captype\FigName
     \def\currentcaption{\figurecaptionsize{#1. #2}}
  \else
  \fi
  \vskip\abovecaptionskip
  \sbox\@tempboxa{\currentcaption}%
  \ifdim \wd\@tempboxa >\hsize
    \currentcaption\par
  \else
    \global \@minipagefalse
    \hb@xt@\hsize{\hfil\box\@tempboxa\hfil}%
  \fi
  \vskip\belowcaptionskip}

