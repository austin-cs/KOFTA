% File JISE.sty
% This is the LaTeX style file for the Journal of Information Science and Engineering
% Papers are to be prepared using the ``JISEbib'' bibliography style,
% as follows:
%       \documentclass[10pt,a4paper,twoside]{article}
%       \usepackage{JISE}
%       \title{Title}
%       \author{Author 1, Author 2 \\ Address line \\ Address line}
%       \begin{document}
%       ...
%       \bibliography{bibliography-file}
%       \bibliographystyle{JISEbib}
%       \end{document}

% If the title and author information does not fit in the area allocated,
% place \setlength\titlebox{<new height>} right after
% \usepackage{JISE}
% where <new height> can be something larger than 5cm

\typeout{LaTeX Style for JISE -- prepared Dec. 2016}
