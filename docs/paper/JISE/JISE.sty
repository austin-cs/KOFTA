  {-1em}%
  {\normalsize\bf}}%

% section number with a dot from secdot package
% command to declare a particular section level to have a dot after
% its number
\newcommand\sectiondot[1]{%
  \expandafter\def\csname @seccntfmt@#1\endcsname##1{%
    \csname the##1\endcsname.\quad
  }
}

% do this by default for \section numbering
\sectiondot{section}

% generalised version: define that #2 comes after section level #1
\newcommand\sectionpunct[2]{%
  \expandafter\def\csname @seccntfmt@#1\endcsname##1{%
    \csname the##1\endcsname#2%
  }%
}

% the guts of the package: insert the dots where needed ... 
\renewcommand\@seccntformat[1]{\@ifundefined{@seccntfmt@#1}%
  {\csname the#1\endcsname\quad}% original default style
  {\csname @seccntfmt@#1\endcsname{#1}}%
}

% Footnotes
\footnotesep 6pt %
\skip\footins 9pt plus 4pt minus 2pt
\def\footnoterule{\kern-3pt \hrule width 5cm \kern 2.6pt }
\def\@makefntext#1{\parindent 0em\indent\hbox{\@makefnmark}#1}
\setcounter{footnote}{0}

% LIST SPACING CONTROLS

% Controls the amount of EXTRA spacing
% above and below \trivlist 
% Both \list and IED lists override this.
% However, \trivlist will use this as will most
% things built from \trivlist like the \center
% environment.
\topsep           10pt

% Controls the additional spacing around lists preceded
% or followed by blank lines.
% \z@ is the same as zero, but faster.
\partopsep          \z@

% Controls the spacing between paragraphs in lists. 
\parsep             \z@

% Controls the extra spacing between list items. 
\itemsep            \z@

% \itemindent is the amount to indent the FIRST line of a list
% item. It is auto set to zero within the \list environment. To alter
% it, you have to do so when you call the \list.
\itemindent         -1em

% \leftmargin, the spacing from the left margin of the main text to
% the left of the main body of a list item is set by \list.
% Hence this statement does nothing for lists.
% But, quote and verse do use it for indention.
\leftmargin         2em

% Footnote without marker for copyright/licence statement
% Code taken from
% http://tex.stackexchange.com/questions/30720/footnote-without-a-marker
% which claims to have taken it, in turn, from
% http://help-csli.stanford.edu/tex/latex-footnotes.shtml#unnumber
% Note the comment that there may be numbering problems if
% you are using the hyperref package. 
\def\editorfootnote{\xdef\@thefnmark{}\@footnotetext}

% Get author and title running
\newtoks\authorrunning
\newtoks\titlerunning

\def\ps@titlepagestyle{% default title page headers, no footers
\def\@oddhead{\parbox{\textwidth}{\sc\headersize Journal of Information Science and Engineering XX, XXXX-XXXX (2024)\hbox{}\hss\\DOI: xx.xxx.xxxx.xx}}%
\def\@evenhead{\relax}%
\def\@oddfoot{\hbox{}\hss\thepage\hbox{}\hss}\relax
\def\@evenfoot{\hbox{}\hss\thepage\hbox{}\hss}\relax
}

% Title stuff, taken from deproc.
\def\maketitle{\par
 \begingroup
   \def\thefootnote{\fnsymbol{footnote}}
   \def\@makefnmark{\hbox to 0pt{$^{\@thefnmark}$\hss}}
   \@maketitle \@thanks
   \thispagestyle{titlepagestyle}
 \endgroup
 \setcounter{footnote}{0}
 \let\maketitle\relax \let\@maketitle\relax
 \gdef\@thanks{}\gdef\@author{}\gdef\@title{}\let\thanks\relax
 \edef\@author{\the\authorrunning}%
 \edef\@title{\the\titlerunning}%
 \def\@evenhead{\sc\headersize \thepage  \hfil \@author \hfil}%
 \def\@oddhead{\sc\headersize  \hfil \@title \hfil \thepage}%
 \markboth{\@oddhead}{\@evenhead}%
}

\def\@maketitle{
   \vbox to \titlebox{\hsize\textwidth 
   \linewidth\hsize \vskip 0.125in minus 0.125in%
   \centering
   \renewcommand\arraystretch{0.8}
   {\Large\bf \@title \par} \vskip 18pt plus 1pt minus 1pt
   {\hbox to \linewidth\bgroup\large \hfil\hfil
    \hbox to 0pt \bgroup\hss 
                     \begin{tabular}[t]{c}%
                     \sc\@author%
                     \end{tabular}\hss\egroup
    \hfil\hfil\egroup}
  \vskip 18pt plus 1pt minus 1pt
}}

% Headings

% change table font size
\let\originaltable\table
\let\originalendtable\endtable
\renewenvironment{table}[1][ht]
