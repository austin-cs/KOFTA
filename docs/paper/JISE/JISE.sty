  {-4ex \@plus -0.5ex \@minus -0.2ex}%
  {3ex \@plus 0.3ex \@minus .2ex}%
  {\large\bf\centering}}%

\renewcommand{\subsection}{\@startsection
  {subsection}%
  {2}%
  {\z@}%
  {-1.8ex \@plus -0.5ex \@minus -0.2ex}%
  {1.5ex \@plus .2ex}%
  {\normalsize\bf\raggedright}}%

\renewcommand{\subsubsection}{\@startsection
  {subsubsection}%
  {3}%
  {\z@}%
